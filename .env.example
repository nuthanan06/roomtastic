# ============================================
# Roomtastic Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ---- Backend / Database ----
# PostgreSQL connection string
# Local development default: postgresql+psycopg://roomtastic:roomtastic@localhost:5432/roomtastic
# Docker Compose default: postgresql+psycopg://roomtastic:roomtastic@db:5432/roomtastic
DATABASE_URL=postgresql+psycopg://roomtastic:roomtastic@localhost:5432/roomtastic

# Python output buffering (set to 1 for unbuffered output in logs)
PYTHONUNBUFFERED=1

# ---- Frontend ----
# Backend API URL accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Supabase (Image Storage) ----
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase API key (anon or service_role)
SUPABASE_KEY=your_supabase_key_here

# Bucket name in Supabase Storage for uploaded images
SUPABASE_BUCKETNAME=roomtastic-images

# ---- Meshy AI (3D Model Generation) ----
# API key for Meshy.ai (optional, only if using 3D generation)
MESHY_API_KEY=your_meshy_api_key_here

# Meshy API base URL (optional, defaults to https://api.meshy.ai)
MESHY_API_BASE=https://api.meshy.ai

# ---- Workers ----
# Poll interval for job worker in seconds (default: 1.0)
WORKER_POLL_INTERVAL=1.0

# Path to backend directory for workers (optional, defaults to ../backend from workers/)
BACKEND_PATH=../backend
